<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stock Market 19 | Trade</title>
  <link rel="stylesheet" href="style.css">
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
  <div class="container">
    <nav class="sidebar">
      <h2 class="logo">Stock Market 19</span></h2>
      <ul class="nav-links">
        <li><a href="/"><i data-lucide="layout-dashboard"></i><span>Dashboard</span></a></li>
        <li><a href="/trade" class="active"><i data-lucide="badge-dollar-sign"></i><span>Trade</span></a></li>
        <li><a href="/cash"><i data-lucide="wallet"></i><span>Cash Account</span></a></li>
        <li><a href="/orders"><i data-lucide="receipt"></i><span>Orders</span></a></li>
        <li><a href="/transactions"><i data-lucide="history"></i><span>Transactions</span></a></li>
        <% if (user && user.role === 'admin') { %>
        <li>
          <a href="/admin-stocks" id="adminNav">
            <i data-lucide="shield"></i><span>Admin</span>
          </a>
        </li>
        <% } %>
        <li>
          <a href="#" id="logoutLink">
            <i data-lucide="log-out"></i>
            <span>Sign Out</span>
          </a>
        </li>
      </ul>
    </nav>

    <main class="main">
      <header class="topbar">
        <div>
          <h1>Trade Stock</h1>
          <p>Orders are placed as pending first so the customer can cancel before execution.</p>
        </div>
        <div class="badge" id="marketBadge"></div>
      </header>

      <div class="grid-2">
        <section class="form-card">
          <h2>Place Order</h2>
          <form id="tradeForm">
            <div class="form-row">
              <label>Stock</label>
              <select id="stockSelect"></select>
            </div>
            <div class="grid-2">
              <div class="form-row">
                <label>Price Per Share</label>
                <input id="priceField" disabled>
              </div>
              <div class="form-row">
                <label>Quantity</label>
                <input id="quantityField" type="number" min="1" required placeholder="Number of shares">
              </div>
            </div>
            <div class="form-row">
              <label>Total</label>
              <input id="totalField" disabled>
            </div>
            <div class="btn-row">
              <button type="button" class="action-btn" id="buyBtn">Place Buy Order</button>
              <button type="button" class="secondary-btn" id="sellBtn">Place Sell Order</button>
            </div>
            <p class="message" id="tradeMessage"></p>
          </form>
        </section>

        <section class="card">
          <h2>Selected Stock</h2>
          <div id="stockPreview"></div>
        </section>
      </div>

      <section>
        <div class="section-header">
          <h2>Pending Orders</h2>
          <a class="secondary-btn" href="/orders">Manage Orders</a>
        </div>
        <div id="pendingOrders"></div>
      </section>
    </main>
  </div>

  <script src="js/app.js"></script>
