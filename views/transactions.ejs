<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stock Market 19 | Transactions</title>
  <link rel="stylesheet" href="style.css">
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
  <div class="container">
    <nav class="sidebar">
      <h2 class="logo">Stock Market 19</span></h2>
      <ul class="nav-links">
        <li><a href="/index"><i data-lucide="layout-dashboard"></i><span>Dashboard</span></a></li>
        <li><a href="/trade"><i data-lucide="badge-dollar-sign"></i><span>Trade</span></a></li>
        <li><a href="/cash"><i data-lucide="wallet"></i><span>Cash Account</span></a></li>
        <li><a href="/orders"><i data-lucide="receipt"></i><span>Orders</span></a></li>
        <li><a href="/transactions" class="active"><i data-lucide="history"></i><span>Transactions</span></a></li>
        <li><a href="/admin-stocks" id="adminNav"><i data-lucide="shield"></i><span>Admin</span></a></li>
      </ul>
    </nav>

    <main class="main">
      <header class="topbar">
        <div>
          <h1>Transaction History</h1>
          <p>Includes deposits, withdrawals, buys, sells, and order status changes.</p>
        </div>
      </header>
      <div id="txArea"></div>
    </main>
  </div>

  <script src="js/app.js"></script>
  <script>
    lucide.createIcons();
    const user = App.requireAuth(['customer', 'admin']);
    if (!user) {}
    document.getElementById('adminNav').style.display = user.role === 'admin' ? 'flex' : 'none';

    const tx = App.getUserTransactions(user.id);
    document.getElementById('txArea').innerHTML = tx.length ? `
      <div class="table-wrap card">
        <table>
          <thead><tr><th>Date</th><th>Type</th><th>Symbol</th><th>Qty</th><th>Description</th><th>Amount</th><th>Status</th></tr></thead>
          <tbody>
            ${tx.map(item => `
              <tr>
                <td>${new Date(item.date).toLocaleString()}</td>
                <td>${item.type}</td>
                <td>${item.symbol || '-'}</td>
                <td>${item.quantity || '-'}</td>
                <td>${item.description || '-'}</td>
                <td>${App.currency(item.amount || 0)}</td>
                <td>${item.status || '-'}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    ` : '<div class="empty-state">No transactions recorded yet.</div>';
  </script>
</body>
</html>
