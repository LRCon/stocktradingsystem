<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stock Market 19 | Dashboard</title>
  <link rel="stylesheet" href="style.css">
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
  <div class="container">
    <nav class="sidebar">
      <h2 class="logo">Stock Market 19</span></h2>
      <ul class="nav-links">
        <li><a href="/" class="active"><i data-lucide="layout-dashboard"></i><span>Dashboard</span></a></li>
        <li><a href="/trade"><i data-lucide="badge-dollar-sign"></i><span>Trade</span></a></li>
        <li><a href="/cash"><i data-lucide="wallet"></i><span>Cash Account</span></a></li>
        <li><a href="/orders"><i data-lucide="receipt"></i><span>Orders</span></a></li>
        <li><a href="/transactions"><i data-lucide="history"></i><span>Transactions</span></a></li>
        <% if (user && user.role === 'admin') { %>
        <li>
          <a href="/admin-stocks" id="adminNav">
            <i data-lucide="shield"></i><span>Admin</span>
          </a>
        </li>
        <% } %>
      </ul>
      <div class="sidebar-card">
        <div class="sidebar-label">Signed in user</div>
        <div class="user-chip">
          <strong id="userName"></strong>
          <small id="userMeta"></small>
        </div>
        <div class="btn-row" style="margin-top:12px;">
          <button class="secondary-btn" id="simulateBtn" type="button">Simulate Prices</button>
          <button class="danger-btn" id="logoutBtn" type="button">Logout</button>
        </div>
      </div>
    </nav>

    <main class="main">
      <header class="topbar">
        <div>
          <h1>Dashboard</h1>
          <p>Customer portfolio and market overview with mock data while backend integration is pending.</p>
        </div>
        <div class="badge" id="marketBadge"></div>
      </header>

      <section class="inline-kpis">
        <div class="card">
          <div class="muted">Portfolio Value</div>
          <div class="kpi" id="portfolioValue"></div>
        </div>
        <div class="card">
          <div class="muted">Cash Account</div>
          <div class="kpi" id="cashValue"></div>
        </div>
        <div class="card">
          <div class="muted">Market Hours</div>
          <div class="kpi" id="marketHours"></div>
          <div class="subtext" id="marketText"></div>
        </div>
      </section>

      <div class="grid-2" style="margin-top:24px;">
        <section class="card">
          <div class="section-header"><h2>Your Holdings</h2></div>
          <div id="holdingsArea"></div>
        </section>

        <section class="card">
          <div class="section-header"><h2>Recent Activity</h2></div>
          <div id="recentActivity"></div>
        </section>
      </div>

      <section>
        <div class="section-header">
          <h2>Available Stocks</h2>
          <a class="secondary-btn" href="/trade">Place Trade</a>
        </div>
        <div id="stockGrid" class="stock-grid"></div>
      </section>
    </main>
  </div>

  <script src="js/app.js"></script>
  <script>
    lucide.createIcons();
    const user = App.requireAuth(['customer', 'admin']);
    if (!user) {}

    document.getElementById('userName').textContent = user.fullName;
    document.getElementById('userMeta').textContent = `${user.role} • ${user.email}`;
    document.getElementById('adminNav').style.display = user.role === 'admin' ? 'flex' : 'none';

    function renderPage() {
      const portfolio = App.getPortfolio(user.id);
      const stocks = App.getStocks();
      const prices = Object.fromEntries(stocks.map(stock => [stock.symbol, stock.currentPrice]));
      let holdingsValue = 0;
      portfolio.holdings.forEach(item => {
        holdingsValue += (prices[item.symbol] || 0) * item.quantity;
      });
      document.getElementById('cashValue').textContent = App.currency(portfolio.cash);
      document.getElementById('portfolioValue').textContent = App.currency(portfolio.cash + holdingsValue);

      const market = App.marketSummary();
      const badge = document.getElementById('marketBadge');
      badge.textContent = market.status;
      badge.className = `badge ${App.isMarketOpen() ? 'success' : 'warning'}`;
      document.getElementById('marketHours').textContent = market.hours;
      document.getElementById('marketText').textContent = 'Weekdays only. Closed on listed holidays.';

      const holdingsArea = document.getElementById('holdingsArea');
      if (!portfolio.holdings.length) {
        holdingsArea.innerHTML = '<div class="empty-state">No holdings yet. Use the trade page to place your first order.</div>';
      } else {
        holdingsArea.innerHTML = `
          <div class="table-wrap">
            <table>
              <thead><tr><th>Symbol</th><th>Shares</th><th>Price</th><th>Value</th></tr></thead>
              <tbody>
                ${portfolio.holdings.map(item => `
                  <tr>
                    <td>${item.symbol}</td>
                    <td>${item.quantity}</td>
                    <td>${App.currency(prices[item.symbol] || 0)}</td>
                    <td>${App.currency((prices[item.symbol] || 0) * item.quantity)}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        `;
      }

      const transactions = App.getUserTransactions(user.id).slice(0, 5);
      const recent = document.getElementById('recentActivity');
      recent.innerHTML = transactions.length ? `
        <div class="table-wrap">
          <table>
            <thead><tr><th>Type</th><th>Description</th><th>Amount</th><th>Status</th></tr></thead>
            <tbody>
              ${transactions.map(tx => `
                <tr>
                  <td>${tx.type}</td>
                  <td>${tx.description || '-'}</td>
                  <td>${App.currency(tx.amount || 0)}</td>
                  <td>${tx.status}</td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      ` : '<div class="empty-state">No transactions yet.</div>';

      document.getElementById('stockGrid').innerHTML = stocks.map(stock => `
        <article class="stock-card">
          <h3>${stock.companyName}</h3>
          <div class="subtext">${stock.symbol}</div>
          <div class="price">${App.currency(stock.currentPrice)}</div>
          <div class="meta-list">
            <div>Volume: ${stock.volume.toLocaleString()}</div>
            <div>Market Cap: ${App.currency(App.marketCap(stock))}</div>
            <div>Open: ${App.currency(stock.openingPrice)}</div>
            <div>High: ${App.currency(stock.dayHigh)} • Low: ${App.currency(stock.dayLow)}</div>
          </div>
        </article>
      `).join('');
    }

    document.getElementById('logoutBtn').addEventListener('click', () => {
      App.logout();
      window.location.href = '/login';
    });
    document.getElementById('simulateBtn').addEventListener('click', () => {
      App.simulatePrices();
      renderPage();
    });

    renderPage();
  </script>
</body>
</html>
