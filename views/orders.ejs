  <script>
  lucide.createIcons();

  const logoutLink = document.getElementById('logoutLink');
  if (logoutLink) {
    logoutLink.addEventListener('click', async (event) => {
      event.preventDefault();
      await App.logout();
    });
  }

  async function handleOrder(action, id) {
    let result;

    if (action === 'cancel') {
      result = await App.cancelOrder(id);
    } else {
      result = {
        success: false,
        message: 'Execute action is not available.'
      };
    }

    alert(result.success ? `Order ${action}d.` : result.message);
    await renderOrders();
  }

  async function renderOrders() {
    const result = await App.getOrders();
    const area = document.getElementById('ordersArea');

    if (!result.success) {
      area.innerHTML = '<div class="empty-state">Unable to load orders.</div>';
      return;
    }

    if (!result.orders.length) {
      area.innerHTML = '<div class="empty-state">No orders yet. Visit the trade page to place one.</div>';
      return;
    }

    area.innerHTML = `
      <div class="table-wrap card">
        <table>
          <thead>
            <tr>
              <th>Placed</th>
              <th>Type</th>
              <th>Symbol</th>
              <th>Qty</th>
              <th>Total</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            ${result.orders.map(order => `
              <tr>
                <td>${new Date(order.created_at).toLocaleString()}</td>
                <td>${order.order_type}</td>
                <td>${order.symbol}</td>
                <td>${order.quantity}</td>
                <td>$${Number(order.total).toFixed(2)}</td>
                <td>${order.status}</td>
                <td>
                  ${order.status === 'Pending' ? `
                    <div class="row-actions">
                      <button class="danger-btn" onclick="handleOrder('cancel', ${order.id})">Cancel</button>
                    </div>
                  ` : '<span class="muted">No action</span>'}
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
  }

  window.handleOrder = handleOrder;
  renderOrders();
</script>
</body>
</html>
