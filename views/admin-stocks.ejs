  <script>
  lucide.createIcons();

  const logoutLink = document.getElementById('logoutLink');
  if (logoutLink) {
    logoutLink.addEventListener('click', async (event) => {
      event.preventDefault();
      await App.logout();
    });
  }

  async function renderStocks() {
    const result = await App.getStocks();
    const stockTable = document.getElementById('stockTable');

    if (!result.success) {
      stockTable.innerHTML = '<div class="empty-state">Unable to load stocks.</div>';
      return;
    }

    if (!result.stocks.length) {
      stockTable.innerHTML = '<div class="empty-state">No stocks created yet.</div>';
      return;
    }

    stockTable.innerHTML = `
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Ticker</th>
              <th>Company</th>
              <th>Price</th>
              <th>Volume</th>
              <th>Open</th>
              <th>High</th>
              <th>Low</th>
            </tr>
          </thead>
          <tbody>
            ${result.stocks.map(stock => `
              <tr>
                <td>${stock.symbol}</td>
                <td>${stock.name}</td>
                <td>$${Number(stock.price).toFixed(2)}</td>
                <td>${Number(stock.volume).toLocaleString()}</td>
                <td>$${Number(stock.opening_price).toFixed(2)}</td>
                <td>$${Number(stock.high).toFixed(2)}</td>
                <td>$${Number(stock.low).toFixed(2)}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
  }

  async function renderSchedule() {
    const result = await App.getMarketSettings();

    if (!result.success) {
      const message = document.getElementById('scheduleMessage');
      message.className = 'message error-text';
      message.textContent = 'Unable to load market schedule.';
      return;
    }

    const settings = result.settings;

    document.getElementById('openTime').value = String(settings.open_time).slice(0, 5);
    document.getElementById('closeTime').value = String(settings.close_time).slice(0, 5);
    document.getElementById('weekdaysOnly').value = String(settings.weekdays_only);
    document.getElementById('marketOpen').value = String(settings.trading_enabled);
  }

  async function renderHolidays() {
    const result = await App.getMarketHolidays();
    const holidayList = document.getElementById('holidayList');

    if (!result.success) {
      holidayList.innerHTML = '<div class="empty-state">Unable to load holidays.</div>';
      return;
    }

    if (!result.holidays.length) {
      holidayList.innerHTML = '<div class="empty-state">No holidays added.</div>';
      return;
    }

    holidayList.innerHTML = `
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Holiday</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            ${result.holidays.map(item => `
              <tr>
                <td>${item.holiday_date}</td>
                <td>
                  <button
                    class="danger-btn"
                    type="button"
                    onclick="removeHoliday(${item.id})"
                  >
                    Remove
                  </button>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
  }

  document.getElementById('createStockForm').addEventListener('submit', async (event) => {
    event.preventDefault();

    const result = await App.createStock({
      companyName: document.getElementById('companyName').value.trim(),
      symbol: document.getElementById('ticker').value.trim().toUpperCase(),
      initialPrice: Number(document.getElementById('initialPrice').value),
      volume: Number(document.getElementById('volume').value)
    });

    const message = document.getElementById('stockMessage');
    message.className = result.success ? 'message success-text' : 'message error-text';
    message.textContent = result.message;

    if (result.success) {
      document.getElementById('createStockForm').reset();
      await renderStocks();
    }
  });

  document.getElementById('scheduleForm').addEventListener('submit', async (event) => {
    event.preventDefault();

    const result = await App.updateMarketSettings({
      openTime: document.getElementById('openTime').value,
      closeTime: document.getElementById('closeTime').value,
      weekdaysOnly: document.getElementById('weekdaysOnly').value === 'true',
      tradingEnabled: document.getElementById('marketOpen').value === 'true'
    });

    const message = document.getElementById('scheduleMessage');
    message.className = result.success ? 'message success-text' : 'message error-text';
    message.textContent = result.message;

    if (result.success) {
      await renderSchedule();
    }
  });

  document.getElementById('holidayForm').addEventListener('submit', async (event) => {
    event.preventDefault();

    const holidayDate = document.getElementById('holidayDate').value;
    if (!holidayDate) return;

    const result = await App.addMarketHoliday(holidayDate);

    const message = document.getElementById('scheduleMessage');
    message.className = result.success ? 'message success-text' : 'message error-text';
    message.textContent = result.message;

    if (result.success) {
      document.getElementById('holidayForm').reset();
      await renderHolidays();
    }
  });

  async function removeHoliday(holidayId) {
    const result = await App.deleteMarketHoliday(holidayId);

    const message = document.getElementById('scheduleMessage');
    message.className = result.success ? 'message success-text' : 'message error-text';
    message.textContent = result.message;

    if (result.success) {
      await renderHolidays();
    }
  }

  window.removeHoliday = removeHoliday;

  renderStocks();
  renderSchedule();
  renderHolidays();
</script>
</body>
</html>