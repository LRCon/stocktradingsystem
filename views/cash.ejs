<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stock Market 19 | Cash Account</title>
  <link rel="stylesheet" href="style.css">
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>
  <div class="container">
    <nav class="sidebar">
      <h2 class="logo">Stock Market 19</span></h2>
      <ul class="nav-links">
        <li><a href="index.html"><i data-lucide="layout-dashboard"></i><span>Dashboard</span></a></li>
        <li><a href="trade.html"><i data-lucide="badge-dollar-sign"></i><span>Trade</span></a></li>
        <li><a href="cash.html" class="active"><i data-lucide="wallet"></i><span>Cash Account</span></a></li>
        <li><a href="orders.html"><i data-lucide="receipt"></i><span>Orders</span></a></li>
        <li><a href="transactions.html"><i data-lucide="history"></i><span>Transactions</span></a></li>
        <li><a href="admin-stocks.html" id="adminNav"><i data-lucide="shield"></i><span>Admin</span></a></li>
      </ul>
    </nav>

    <main class="main">
      <header class="topbar">
        <div>
          <h1>Cash Account</h1>
          <p>Deposits and withdrawals flow through the customer cash account only.</p>
        </div>
      </header>

      <div class="grid-3">
        <section class="card">
          <div class="muted">Available Cash</div>
          <div class="kpi" id="cashBalance"></div>
        </section>
        <section class="card">
          <div class="muted">Pending Orders</div>
          <div class="kpi" id="pendingOrderCount"></div>
        </section>
        <section class="card">
          <div class="muted">Completed Cash Entries</div>
          <div class="kpi" id="cashTxnCount"></div>
        </section>
      </div>

      <div class="grid-2" style="margin-top:24px;">
        <section class="form-card">
          <h2>Deposit Cash</h2>
          <form id="depositForm">
            <div class="form-row">
              <label>Amount</label>
              <input type="number" min="0.01" step="0.01" id="depositAmount" placeholder="2500.00">
            </div>
            <button class="action-btn" type="submit">Deposit</button>
            <p class="message" id="depositMessage"></p>
          </form>
        </section>

        <section class="form-card">
          <h2>Withdraw Cash</h2>
          <form id="withdrawForm">
            <div class="form-row">
              <label>Amount</label>
              <input type="number" min="0.01" step="0.01" id="withdrawAmount" placeholder="500.00">
            </div>
            <button class="secondary-btn" type="submit">Withdraw</button>
            <p class="message" id="withdrawMessage"></p>
          </form>
        </section>
      </div>
    </main>
  </div>

  <script src="js/app.js"></script>
  <script>
    lucide.createIcons();
    const user = App.requireAuth(['customer', 'admin']);
    if (!user) {}
    document.getElementById('adminNav').style.display = user.role === 'admin' ? 'flex' : 'none';

    function render() {
      const portfolio = App.getPortfolio(user.id);
      document.getElementById('cashBalance').textContent = App.currency(portfolio.cash);
      document.getElementById('pendingOrderCount').textContent = App.getUserOrders(user.id).filter(order => order.status === 'Pending').length;
      document.getElementById('cashTxnCount').textContent = App.getUserTransactions(user.id).filter(tx => ['Deposit', 'Withdrawal'].includes(tx.type)).length;
    }

    document.getElementById('depositForm').addEventListener('submit', (event) => {
      event.preventDefault();
      const amount = Number(document.getElementById('depositAmount').value);
      const result = App.depositCash(user.id, amount);
      const message = document.getElementById('depositMessage');
      message.className = result.success ? 'message success-text' : 'message error-text';
      message.textContent = result.success ? 'Deposit completed.' : result.message;
      if (result.success) document.getElementById('depositForm').reset();
      render();
    });

    document.getElementById('withdrawForm').addEventListener('submit', (event) => {
      event.preventDefault();
      const amount = Number(document.getElementById('withdrawAmount').value);
      const result = App.withdrawCash(user.id, amount);
      const message = document.getElementById('withdrawMessage');
      message.className = result.success ? 'message success-text' : 'message error-text';
      message.textContent = result.success ? 'Withdrawal completed.' : result.message;
      if (result.success) document.getElementById('withdrawForm').reset();
      render();
    });

    render();
  </script>
</body>
</html>
